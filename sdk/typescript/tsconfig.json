{
  "compilerOptions": {
    "exactOptionalPropertyTypes": true,
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["src/*.d.mts", "type-tests/*.mts"]
}
